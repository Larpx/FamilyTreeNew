@model FamilyTreeNew.Models.DTOs.PagedResult<AdminDto>
@{
    ViewData["Title"] = "管理员管理";
    Layout = "_AdminLayout";
}

<div class="page-header">
    <div class="row align-items-center">
        <div class="col">
            <h1 class="page-title">管理员管理</h1>
            <p class="page-subtitle">管理系统管理员账户</p>
        </div>
        <div class="col-auto">
            <a asp-action="Create" class="btn btn-primary">
                <i class="bi bi-plus-lg me-1"></i>添加管理员
            </a>
        </div>
    </div>
</div>

<div class="card">
    <div class="card-header">
        <form method="get" class="row g-3 align-items-end">
            <div class="col-md-6">
                <label class="form-label">关键词搜索</label>
                <input type="text" name="keyword" value="@ViewBag.Keyword" class="form-control" placeholder="搜索用户名或姓名...">
            </div>
            <div class="col-md-6">
                <button type="submit" class="btn btn-outline-primary me-2">
                    <i class="bi bi-search me-1"></i>搜索
                </button>
                <a asp-action="Index" class="btn btn-outline-secondary">
                    <i class="bi bi-arrow-counterclockwise me-1"></i>重置
                </a>
            </div>
        </form>
    </div>
    
    <div class="card-body">
        @if (Model.Items.Any())
        {
            <div class="table-responsive">
                <table class="table table-hover">
                    <thead>
                        <tr>
                            <th>用户名</th>
                            <th>真实姓名</th>
                            <th>邮箱</th>
                            <th>权限级别</th>
                            <th>状态</th>
                            <th>最后登录</th>
                            <th>创建时间</th>
                            <th>操作</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model.Items)
                        {
                            <tr>
                                <td><strong>@item.Username</strong></td>
                                <td>@(item.RealName ?? "-")</td>
                                <td>@(item.Email ?? "-")</td>
                                <td>
                                    @switch (item.PermissionLevel)
                                    {
                                        case 3:
                                            <span class="badge bg-danger">超级管理员</span>
                                            break;
                                        case 2:
                                            <span class="badge bg-warning">高级管理员</span>
                                            break;
                                        default:
                                            <span class="badge bg-info">普通管理员</span>
                                            break;
                                    }
                                </td>
                                <td>
                                    @if (item.IsEnabled)
                                    {
                                        <span class="badge bg-success">启用</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-secondary">禁用</span>
                                    }
                                </td>
                                <td>
                                    @if (item.LastLoginAt.HasValue)
                                    {
                                        @item.LastLoginAt.Value.ToString("yyyy-MM-dd HH:mm")
                                    }
                                    else
                                    {
                                        <span class="text-muted">从未登录</span>
                                    }
                                </td>
                                <td>@item.CreatedAt.ToString("yyyy-MM-dd")</td>
                                <td>
                                    <div class="btn-group btn-group-sm">
                                        <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-outline-primary" title="编辑">
                                            <i class="bi bi-pencil"></i>
                                        </a>
                                        <form asp-action="Delete" asp-route-id="@item.Id" method="post" 
                                              onsubmit="return confirm('确定要删除这个管理员吗？');" style="display:inline;">
                                            @Html.AntiForgeryToken()
                                            <button type="submit" class="btn btn-outline-danger" title="删除">
                                                <i class="bi bi-trash"></i>
                                            </button>
                                        </form>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
        else
        {
            <div class="text-center py-5 text-muted">
                <i class="bi bi-people fs-1 d-block mb-3"></i>
                <p>暂无管理员数据</p>
            </div>
        }
    </div>
</div>
