@model FamilyTreeNew.Models.DTOs.Auth.ChangePasswordRequestDto
@{
    ViewData["Title"] = "修改密码";
    Layout = "_AdminLayout";
}

<div class="page-header">
    <div class="row align-items-center">
        <div class="col">
            <h1 class="page-title">修改密码</h1>
            <p class="page-subtitle">更新您的登录密码</p>
        </div>
    </div>
</div>

<div class="row">
    <div class="col-lg-6">
        <div class="card">
            <div class="card-header">
                <h5 class="card-title mb-0">密码信息</h5>
            </div>
            <div class="card-body">
                <form asp-action="ChangePassword" method="post">
                    @Html.AntiForgeryToken()
                    
                    <div class="mb-3">
                        <label asp-for="OldPassword" class="form-label">原密码 <span class="text-danger">*</span></label>
                        <input asp-for="OldPassword" class="form-control" type="password" placeholder="请输入原密码">
                        <span asp-validation-for="OldPassword" class="text-danger"></span>
                    </div>
                    
                    <div class="mb-3">
                        <label asp-for="NewPassword" class="form-label">新密码 <span class="text-danger">*</span></label>
                        <input asp-for="NewPassword" class="form-control" type="password" placeholder="请输入新密码">
                        <span asp-validation-for="NewPassword" class="text-danger"></span>
                    </div>
                    
                    <div class="mb-3">
                        <label asp-for="ConfirmPassword" class="form-label">确认新密码 <span class="text-danger">*</span></label>
                        <input asp-for="ConfirmPassword" class="form-control" type="password" placeholder="请再次输入新密码">
                        <span asp-validation-for="ConfirmPassword" class="text-danger"></span>
                    </div>
                    
                    <div class="d-flex gap-2">
                        <button type="submit" class="btn btn-primary">
                            <i class="bi bi-check-lg me-1"></i>修改密码
                        </button>
                        <a asp-controller="Dashboard" asp-action="Index" class="btn btn-outline-secondary">
                            <i class="bi bi-x-lg me-1"></i>取消
                        </a>
                    </div>
                </form>
            </div>
        </div>
    </div>
    
    <div class="col-lg-6">
        <div class="card">
            <div class="card-header">
                <h5 class="card-title mb-0">密码要求</h5>
            </div>
            <div class="card-body">
                <ul class="mb-0">
                    <li class="mb-2">
                        <i class="bi bi-info-circle text-primary me-2"></i>
                        密码长度至少6个字符
                    </li>
                    <li class="mb-2">
                        <i class="bi bi-info-circle text-primary me-2"></i>
                        建议使用字母、数字和特殊字符组合
                    </li>
                    <li class="mb-2">
                        <i class="bi bi-info-circle text-primary me-2"></i>
                        不要使用容易猜测的密码
                    </li>
                    <li>
                        <i class="bi bi-info-circle text-primary me-2"></i>
                        定期更换密码以提高安全性
                    </li>
                </ul>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
