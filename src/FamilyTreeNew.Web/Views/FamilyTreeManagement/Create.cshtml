@model FamilyTreeNew.Models.DTOs.FamilyTreeCreateDto
@{
    ViewData["Title"] = "创建家谱";
    Layout = "_AdminLayout";
}

<div class="page-header">
    <div class="row align-items-center">
        <div class="col">
            <nav aria-label="breadcrumb">
                <ol class="breadcrumb">
                    <li class="breadcrumb-item"><a asp-action="Index">家谱管理</a></li>
                    <li class="breadcrumb-item active">创建家谱</li>
                </ol>
            </nav>
            <h1 class="page-title">创建家谱</h1>
        </div>
    </div>
</div>

<div class="row">
    <div class="col-lg-8">
        <div class="card">
            <div class="card-header">
                <h5 class="card-title mb-0">基本信息</h5>
            </div>
            <div class="card-body">
                <form asp-action="Create" method="post">
                    @Html.AntiForgeryToken()
                    
                    <div class="mb-3">
                        <label asp-for="Name" class="form-label">家谱名称 <span class="text-danger">*</span></label>
                        <input asp-for="Name" class="form-control" placeholder="请输入家谱名称">
                        <span asp-validation-for="Name" class="text-danger"></span>
                    </div>
                    
                    <div class="mb-3">
                        <label asp-for="Description" class="form-label">家谱简介</label>
                        <textarea asp-for="Description" class="form-control" rows="5" placeholder="请输入家谱简介..."></textarea>
                        <span asp-validation-for="Description" class="text-danger"></span>
                    </div>
                    
                    <div class="row">
                        <div class="col-md-6">
                            <div class="mb-3">
                                <div class="form-check form-switch">
                                    <input asp-for="RequireVerification" class="form-check-input" type="checkbox">
                                    <label asp-for="RequireVerification" class="form-check-label">需要验证问题</label>
                                </div>
                                <small class="text-muted">开启后，访客需要回答验证问题才能查看家谱</small>
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="mb-3">
                                <div class="form-check form-switch">
                                    <input asp-for="IsEnabled" class="form-check-input" type="checkbox" checked>
                                    <label asp-for="IsEnabled" class="form-check-label">启用家谱</label>
                                </div>
                                <small class="text-muted">禁用后，家谱将不会在前台显示</small>
                            </div>
                        </div>
                    </div>
                    
                    <div class="d-flex gap-2">
                        <button type="submit" class="btn btn-primary">
                            <i class="bi bi-check-lg me-1"></i>创建
                        </button>
                        <a asp-action="Index" class="btn btn-outline-secondary">
                            <i class="bi bi-x-lg me-1"></i>取消
                        </a>
                    </div>
                </form>
            </div>
        </div>
    </div>
    
    <div class="col-lg-4">
        <div class="card">
            <div class="card-header">
                <h5 class="card-title mb-0">帮助说明</h5>
            </div>
            <div class="card-body">
                <ul class="list-unstyled mb-0">
                    <li class="mb-2">
                        <i class="bi bi-info-circle text-primary me-2"></i>
                        家谱名称建议使用家族姓氏或特定名称
                    </li>
                    <li class="mb-2">
                        <i class="bi bi-info-circle text-primary me-2"></i>
                        家谱简介可以包含家族历史、来源等信息
                    </li>
                    <li class="mb-2">
                        <i class="bi bi-info-circle text-primary me-2"></i>
                        验证问题功能可以保护家谱隐私
                    </li>
                    <li>
                        <i class="bi bi-info-circle text-primary me-2"></i>
                        创建家谱后可以添加成员信息
                    </li>
                </ul>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
