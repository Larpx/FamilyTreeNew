@model FamilyTreeNew.Models.DTOs.AlbumDetailDto
@{
    ViewData["Title"] = "相册详情";
    Layout = "_AdminLayout";
}

<div class="page-header">
    <div class="row align-items-center">
        <div class="col">
            <nav aria-label="breadcrumb">
                <ol class="breadcrumb">
                    <li class="breadcrumb-item"><a asp-action="Index">相册管理</a></li>
                    <li class="breadcrumb-item active">相册详情</li>
                </ol>
            </nav>
            <h1 class="page-title">@Model.Name</h1>
        </div>
        <div class="col-auto">
            <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-primary">
                <i class="bi bi-pencil me-1"></i>编辑
            </a>
        </div>
    </div>
</div>

<div class="row">
    <div class="col-lg-8">
        <div class="card mb-4">
            <div class="card-header">
                <h5 class="card-title mb-0">相册信息</h5>
            </div>
            <div class="card-body">
                <div class="row mb-3">
                    <label class="col-sm-3 col-form-label fw-bold">相册名称</label>
                    <div class="col-sm-9">
                        <p class="form-control-plaintext">@Model.Name</p>
                    </div>
                </div>
                
                <div class="row mb-3">
                    <label class="col-sm-3 col-form-label fw-bold">相册描述</label>
                    <div class="col-sm-9">
                        <p class="form-control-plaintext">
                            @if (!string.IsNullOrEmpty(Model.Description))
                            {
                                @Model.Description
                            }
                            else
                            {
                                <span class="text-muted">暂无描述</span>
                            }
                        </p>
                    </div>
                </div>
                
                <div class="row mb-3">
                    <label class="col-sm-3 col-form-label fw-bold">照片数量</label>
                    <div class="col-sm-9">
                        <p class="form-control-plaintext">
                            <span class="badge bg-info">@Model.PhotoCount 张</span>
                        </p>
                    </div>
                </div>
                
                <div class="row mb-3">
                    <label class="col-sm-3 col-form-label fw-bold">创建时间</label>
                    <div class="col-sm-9">
                        <p class="form-control-plaintext">@Model.CreatedAt.ToString("yyyy-MM-dd HH:mm:ss")</p>
                    </div>
                </div>
            </div>
        </div>
        
        <div class="card">
            <div class="card-header">
                <h5 class="card-title mb-0">相册照片</h5>
            </div>
            <div class="card-body">
                @if (Model.Photos.Any())
                {
                    <div class="row g-3">
                        @foreach (var photo in Model.Photos)
                        {
                            <div class="col-md-4 col-lg-3">
                                <div class="card">
                                    <img data-src="@photo.PhotoPath" src="data:image/gif;base64,R0lGODlhAQABAIAAAAAAAP///yH5BAEAAAAALAAAAAABAAEAAAIBRAA7" alt="@photo.Title" class="card-img-top lazy-img" style="height: 150px; object-fit: cover;">
                                    <div class="card-body p-2">
                                        <p class="card-text small text-truncate">@photo.Title</p>
                                    </div>
                                </div>
                            </div>
                        }
                    </div>
                }
                else
                {
                    <div class="text-center py-4 text-muted">
                        <i class="bi bi-image fs-1 d-block mb-2"></i>
                        <p>暂无照片</p>
                    </div>
                }
            </div>
        </div>
    </div>
    
    <div class="col-lg-4">
        <div class="card mb-4">
            <div class="card-header">
                <h5 class="card-title mb-0">快捷操作</h5>
            </div>
            <div class="card-body">
                <div class="d-grid gap-2">
                    <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-outline-primary">
                        <i class="bi bi-pencil me-1"></i>编辑相册
                    </a>
                </div>
            </div>
        </div>
        
        <div class="card">
            <div class="card-header">
                <h5 class="card-title mb-0">危险操作</h5>
            </div>
            <div class="card-body">
                <form asp-action="Delete" asp-route-id="@Model.Id" method="post" 
                      onsubmit="return confirm('确定要删除这个相册吗？此操作将同时删除所有照片！');">
                    @Html.AntiForgeryToken()
                    <button type="submit" class="btn btn-danger w-100">
                        <i class="bi bi-trash me-1"></i>删除相册
                    </button>
                </form>
            </div>
        </div>
    </div>
</div>

@section Styles {
    <style>
        .lazy-img {
            opacity: 0;
            transition: opacity 0.3s ease-in-out;
        }
        .lazy-img.lazy-loaded {
            opacity: 1;
        }
        .lazy-img.lazy-loading {
            background: #f0f0f0;
        }
        .lazy-img.lazy-error {
            background: #ffebee;
        }
    </style>
}

@section Scripts {
    <script src="~/js/lazy-load.js" asp-append-version="true"></script>
}
