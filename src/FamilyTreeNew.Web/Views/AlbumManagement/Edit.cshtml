@model FamilyTreeNew.Models.DTOs.AlbumUpdateDto
@{
    ViewData["Title"] = "编辑相册";
    Layout = "_AdminLayout";
}

<div class="page-header">
    <div class="row align-items-center">
        <div class="col">
            <nav aria-label="breadcrumb">
                <ol class="breadcrumb">
                    <li class="breadcrumb-item"><a asp-action="Index">相册管理</a></li>
                    <li class="breadcrumb-item active">编辑相册</li>
                </ol>
            </nav>
            <h1 class="page-title">编辑相册</h1>
        </div>
    </div>
</div>

<div class="row">
    <div class="col-lg-8">
        <div class="card">
            <div class="card-header">
                <h5 class="card-title mb-0">基本信息</h5>
            </div>
            <div class="card-body">
                <form asp-action="Edit" asp-route-id="@ViewBag.AlbumId" method="post">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="FamilyTreeId" value="@ViewBag.FamilyTreeId" />
                    
                    <div class="mb-3">
                        <label asp-for="Name" class="form-label">相册名称 <span class="text-danger">*</span></label>
                        <input asp-for="Name" class="form-control" placeholder="请输入相册名称">
                        <span asp-validation-for="Name" class="text-danger"></span>
                    </div>
                    
                    <div class="mb-3">
                        <label asp-for="Description" class="form-label">相册描述</label>
                        <textarea asp-for="Description" class="form-control" rows="4" placeholder="请输入相册描述..."></textarea>
                        <span asp-validation-for="Description" class="text-danger"></span>
                    </div>
                    
                    <div class="d-flex gap-2">
                        <button type="submit" class="btn btn-primary">
                            <i class="bi bi-check-lg me-1"></i>保存
                        </button>
                        <a asp-action="Index" class="btn btn-outline-secondary">
                            <i class="bi bi-x-lg me-1"></i>取消
                        </a>
                    </div>
                </form>
            </div>
        </div>
    </div>
    
    <div class="col-lg-4">
        @if (ViewBag.Photos != null)
        {
            <div class="card">
                <div class="card-header">
                    <h5 class="card-title mb-0">相册照片 (@ViewBag.Photos.Count)</h5>
                </div>
                <div class="card-body">
                    <div class="row g-2">
                        @foreach (var photo in ViewBag.Photos)
                        {
                            <div class="col-4">
                                <img src="@(photo.ThumbnailPath ?? photo.PhotoPath)" class="img-thumbnail" alt="@photo.Title">
                            </div>
                        }
                    </div>
                </div>
            </div>
        }
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
