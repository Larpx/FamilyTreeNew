@model FamilyTreeNew.Models.DTOs.CreateVerificationQuestionDto
@{
    ViewData["Title"] = "添加验证问题";
    Layout = "_AdminLayout";
}

<div class="page-header">
    <div class="row align-items-center">
        <div class="col">
            <nav aria-label="breadcrumb">
                <ol class="breadcrumb">
                    <li class="breadcrumb-item"><a asp-action="Index">验证问题管理</a></li>
                    <li class="breadcrumb-item active">添加验证问题</li>
                </ol>
            </nav>
            <h1 class="page-title">添加验证问题</h1>
        </div>
    </div>
</div>

<div class="row">
    <div class="col-lg-8">
        <div class="card">
            <div class="card-header">
                <h5 class="card-title mb-0">问题信息</h5>
            </div>
            <div class="card-body">
                <form asp-action="Create" method="post">
                    @Html.AntiForgeryToken()
                    
                    <div class="mb-3">
                        <label asp-for="FamilyTreeId" class="form-label">关联家谱 <span class="text-danger">*</span></label>
                        <select asp-for="FamilyTreeId" class="form-select">
                            @if (ViewBag.FamilyTrees != null)
                            {
                                foreach (var tree in ViewBag.FamilyTrees)
                                {
                                    <option value="@tree.Id">@tree.Name</option>
                                }
                            }
                        </select>
                        <span asp-validation-for="FamilyTreeId" class="text-danger"></span>
                    </div>
                    
                    <div class="mb-3">
                        <label asp-for="Question" class="form-label">问题 <span class="text-danger">*</span></label>
                        <input asp-for="Question" class="form-control" placeholder="请输入验证问题">
                        <span asp-validation-for="Question" class="text-danger"></span>
                    </div>
                    
                    <div class="mb-3">
                        <label asp-for="AnswerKeyword" class="form-label">答案关键词 <span class="text-danger">*</span></label>
                        <input asp-for="AnswerKeyword" class="form-control" placeholder="请输入答案关键词">
                        <div class="form-text">访客回答中包含此关键词即视为正确</div>
                        <span asp-validation-for="AnswerKeyword" class="text-danger"></span>
                    </div>
                    
                    <div class="row">
                        <div class="col-md-6">
                            <div class="mb-3">
                                <label asp-for="Order" class="form-label">验证顺序</label>
                                <input asp-for="Order" class="form-control" type="number" min="1">
                                <span asp-validation-for="Order" class="text-danger"></span>
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="mb-3 pt-4">
                                <div class="form-check form-switch">
                                    <input asp-for="IsEnabled" class="form-check-input" type="checkbox" checked>
                                    <label asp-for="IsEnabled" class="form-check-label">启用</label>
                                </div>
                            </div>
                        </div>
                    </div>
                    
                    <div class="d-flex gap-2">
                        <button type="submit" class="btn btn-primary">
                            <i class="bi bi-check-lg me-1"></i>添加
                        </button>
                        <a asp-action="Index" class="btn btn-outline-secondary">
                            <i class="bi bi-x-lg me-1"></i>取消
                        </a>
                    </div>
                </form>
            </div>
        </div>
    </div>
    
    <div class="col-lg-4">
        <div class="card">
            <div class="card-header">
                <h5 class="card-title mb-0">帮助说明</h5>
            </div>
            <div class="card-body">
                <ul class="mb-0">
                    <li class="mb-2">
                        <i class="bi bi-info-circle text-primary me-2"></i>
                        验证问题用于保护家谱隐私
                    </li>
                    <li class="mb-2">
                        <i class="bi bi-info-circle text-primary me-2"></i>
                        答案关键词支持模糊匹配
                    </li>
                    <li>
                        <i class="bi bi-info-circle text-primary me-2"></i>
                        建议设置家族相关的验证问题
                    </li>
                </ul>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
