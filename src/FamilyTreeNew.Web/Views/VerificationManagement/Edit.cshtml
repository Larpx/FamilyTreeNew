@model FamilyTreeNew.Models.DTOs.UpdateVerificationQuestionDto
@{
    ViewData["Title"] = "编辑验证问题";
    Layout = "_AdminLayout";
}

<div class="page-header">
    <div class="row align-items-center">
        <div class="col">
            <nav aria-label="breadcrumb">
                <ol class="breadcrumb">
                    <li class="breadcrumb-item"><a asp-action="Index">验证问题管理</a></li>
                    <li class="breadcrumb-item active">编辑验证问题</li>
                </ol>
            </nav>
            <h1 class="page-title">编辑验证问题</h1>
        </div>
    </div>
</div>

<div class="row">
    <div class="col-lg-8">
        <div class="card">
            <div class="card-header">
                <h5 class="card-title mb-0">问题信息</h5>
            </div>
            <div class="card-body">
                <form asp-action="Edit" asp-route-id="@ViewBag.QuestionId" method="post">
                    @Html.AntiForgeryToken()
                    
                    <div class="mb-3">
                        <label class="form-label">关联家谱</label>
                        <input type="text" class="form-control" value="@ViewBag.FamilyTreeName ?? "未知"" disabled>
                    </div>
                    
                    <div class="mb-3">
                        <label asp-for="Question" class="form-label">问题 <span class="text-danger">*</span></label>
                        <input asp-for="Question" class="form-control" placeholder="请输入验证问题">
                        <span asp-validation-for="Question" class="text-danger"></span>
                    </div>
                    
                    <div class="mb-3">
                        <label asp-for="AnswerKeyword" class="form-label">答案关键词 <span class="text-danger">*</span></label>
                        <input asp-for="AnswerKeyword" class="form-control" placeholder="请输入答案关键词">
                        <div class="form-text">访客回答中包含此关键词即视为正确</div>
                        <span asp-validation-for="AnswerKeyword" class="text-danger"></span>
                    </div>
                    
                    <div class="row">
                        <div class="col-md-6">
                            <div class="mb-3">
                                <label asp-for="Order" class="form-label">验证顺序</label>
                                <input asp-for="Order" class="form-control" type="number" min="1">
                                <span asp-validation-for="Order" class="text-danger"></span>
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="mb-3 pt-4">
                                <div class="form-check form-switch">
                                    <input asp-for="IsEnabled" class="form-check-input" type="checkbox">
                                    <label asp-for="IsEnabled" class="form-check-label">启用</label>
                                </div>
                            </div>
                        </div>
                    </div>
                    
                    <div class="d-flex gap-2">
                        <button type="submit" class="btn btn-primary">
                            <i class="bi bi-check-lg me-1"></i>保存
                        </button>
                        <a asp-action="Index" class="btn btn-outline-secondary">
                            <i class="bi bi-x-lg me-1"></i>取消
                        </a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
