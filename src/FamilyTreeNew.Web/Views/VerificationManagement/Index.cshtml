@model List<FamilyTreeNew.Models.DTOs.VerificationQuestionDto>
@{
    ViewData["Title"] = "验证问题管理";
    Layout = "_AdminLayout";
}

<div class="page-header">
    <div class="row align-items-center">
        <div class="col">
            <h1 class="page-title">验证问题管理</h1>
            <p class="page-subtitle">管理家谱访问验证问题</p>
        </div>
        <div class="col-auto">
            <a asp-action="Create" class="btn btn-primary">
                <i class="bi bi-plus-lg me-1"></i>添加问题
            </a>
        </div>
    </div>
</div>

<div class="card">
    <div class="card-body">
        @if (Model.Any())
        {
            <div class="table-responsive">
                <table class="table table-hover">
                    <thead>
                        <tr>
                            <th style="width: 50px;">#</th>
                            <th>问题</th>
                            <th>关联家谱</th>
                            <th>顺序</th>
                            <th>状态</th>
                            <th style="width: 150px;">操作</th>
                        </tr>
                    </thead>
                    <tbody>
                        @for (int i = 0; i < Model.Count; i++)
                        {
                            <tr>
                                <td>@(i + 1)</td>
                                <td>@Model[i].Question</td>
                                <td>
                                    @if (!string.IsNullOrEmpty(Model[i].FamilyTreeName))
                                    {
                                        <span class="badge bg-info">@Model[i].FamilyTreeName</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-secondary">通用</span>
                                    }
                                </td>
                                <td>@Model[i].Order</td>
                                <td>
                                    @if (Model[i].IsEnabled)
                                    {
                                        <span class="badge bg-success">启用</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-secondary">禁用</span>
                                    }
                                </td>
                                <td>
                                    <div class="btn-group btn-group-sm">
                                        <a asp-action="Edit" asp-route-id="@Model[i].Id" class="btn btn-outline-primary" title="编辑">
                                            <i class="bi bi-pencil"></i>
                                        </a>
                                        <form asp-action="Delete" asp-route-id="@Model[i].Id" method="post" 
                                              onsubmit="return confirm('确定要删除这个验证问题吗？');" style="display:inline;">
                                            @Html.AntiForgeryToken()
                                            <button type="submit" class="btn btn-outline-danger" title="删除">
                                                <i class="bi bi-trash"></i>
                                            </button>
                                        </form>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
        else
        {
            <div class="text-center py-5 text-muted">
                <i class="bi bi-question-circle fs-1 d-block mb-3"></i>
                <p>暂无验证问题</p>
                <a asp-action="Create" class="btn btn-primary">
                    <i class="bi bi-plus-lg me-1"></i>添加第一个问题
                </a>
            </div>
        }
    </div>
</div>
