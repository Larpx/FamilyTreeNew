@model ErrorViewModel
@{
    ViewData["Title"] = Model.Title;
}

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-lg-8 col-xl-6">
            <div class="card shadow-sm border-0">
                <div class="card-body p-4 p-md-5 text-center">
                    <div class="display-3 fw-bold text-warning mb-3">@Model.StatusCode</div>
                    <h1 class="h3 mb-3">@Model.Title</h1>
                    <p class="text-muted mb-4">@Model.Message</p>

                    <div class="d-flex flex-wrap justify-content-center gap-2 mb-4">
                        <a class="btn btn-primary" href="@Url.Action("Index", "Home")">返回首页</a>
                        <a class="btn btn-outline-secondary" href="javascript:history.back()">返回上一页</a>
                    </div>

                    @if (Model.ShowRequestId)
                    {
                        <div class="small text-muted">
                            请求跟踪号：<code>@Model.RequestId</code>
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>
</div>
