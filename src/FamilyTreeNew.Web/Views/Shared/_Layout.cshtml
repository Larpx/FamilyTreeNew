<!DOCTYPE html>
<html lang="zh-CN">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no" />
    <title>@ViewData["Title"] - 家族族谱</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/FamilyTreeNew.Web.styles.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/family-tree.css" asp-append-version="true" />
    <link href="https://fonts.font.im/css2?family=Outfit:wght@300;400;500;600;700&family=Work+Sans:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/@@fortawesome/fontawesome-free@6.4.0/css/all.min.css" />
</head>
<body>
    <header class="fixed-top">
        <nav class="navbar navbar-expand-lg navbar-light bg-white shadow-sm">
            <div class="container-fluid px-4">
                <a class="navbar-brand brand-text" asp-area="" asp-controller="Home" asp-action="Index">
                    <span class="brand-icon">族</span>
                    <span class="brand-name">家族族谱</span>
                </a>
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav" aria-controls="navbarNav" aria-expanded="false" aria-label="切换导航">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="collapse navbar-collapse" id="navbarNav">
                    <ul class="navbar-nav ms-auto">
                        <li class="nav-item">
                            <a class="nav-link" asp-area="" asp-controller="Home" asp-action="Index">
                                <i class="fas fa-home me-2"></i>首页
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" asp-area="" asp-controller="FamilyTree" asp-action="Index">
                                <i class="fas fa-sitemap me-2"></i>家谱展示
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" asp-area="" asp-controller="Home" asp-action="Privacy">
                                <i class="fas fa-info-circle me-2"></i>关于我们
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" asp-area="" asp-controller="Admin" asp-action="Login">
                                <i class="fas fa-user-shield me-2"></i>后台管理
                            </a>
                        </li>
                    </ul>
                </div>
            </div>
        </nav>
    </header>
    <main role="main" class="pt-16">
        @RenderBody()
    </main>

    <footer class="footer">
        <div class="container py-6">
            <div class="row">
                <div class="col-md-6 mb-4 mb-md-0">
                    <div class="footer-brand mb-3">
                        <span class="brand-icon footer-icon">族</span>
                        <span class="brand-name footer-brand-name">家族族谱</span>
                    </div>
                    <p class="footer-desc">传承家族文化，延续血脉亲情</p>
                    <div class="footer-social mt-4">
                        <a href="#" class="social-link"><i class="fab fa-weixin"></i></a>
                        <a href="#" class="social-link"><i class="fab fa-weibo"></i></a>
                        <a href="#" class="social-link"><i class="fas fa-envelope"></i></a>
                    </div>
                </div>
                <div class="col-md-6 text-md-end">
                    <p class="footer-info">&copy; 2026 家族族谱系统</p>
                    <p class="footer-info">更新日期：@DateTime.Now.ToString("yyyy年MM月dd日")</p>
                    <p class="footer-icp">网站备案号：京ICP备XXXXXXXX号</p>
                </div>
            </div>
        </div>
    </footer>
    <script nonce="@Context.Items["CspNonce"]" src="https://cdn.jsdelivr.net/npm/jquery@3.7.0/dist/jquery.min.js"></script>
    <script nonce="@Context.Items["CspNonce"]" src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <script nonce="@Context.Items["CspNonce"]" src="~/js/site.js" asp-append-version="true"></script>
    <script nonce="@Context.Items["CspNonce"]" src="~/js/lazy-load.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
