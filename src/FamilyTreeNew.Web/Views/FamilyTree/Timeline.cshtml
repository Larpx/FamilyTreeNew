@{
    ViewData["Title"] = "时间轴 - " + (ViewBag.FamilyTree?.Name ?? "家谱");
    var familyTree = ViewBag.FamilyTree as FamilyTreeNew.Models.DTOs.FamilyTreeDto;
    var members = ViewBag.Members as List<FamilyTreeNew.Models.DTOs.FamilyMemberDto>;
}

<div class="chart-page timeline-page">
    <div class="chart-toolbar">
        <div class="toolbar-left">
            <h3 class="chart-title">
                <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" fill="currentColor" viewBox="0 0 16 16">
                    <path d="M8 3.5a.5.5 0 0 0-1 0V9a.5.5 0 0 0 .252.434l3.5 2a.5.5 0 0 0 .496-.868L8 8.71V3.5z"/>
                    <path d="M8 16A8 8 0 1 0 8 0a8 8 0 0 0 0 16zm7-8A7 7 0 1 1 1 8a7 7 0 0 1 14 0z"/>
                </svg>
                时间轴展示
            </h3>
        </div>
        <div class="toolbar-right">
            <div class="filter-group">
                <select id="event-filter" class="filter-select">
                    <option value="all">全部事件</option>
                    <option value="birth">出生事件</option>
                    <option value="death">逝世事件</option>
                </select>
            </div>
            <div class="view-toggle">
                <button class="toggle-btn active" data-view="vertical">
                    <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" viewBox="0 0 16 16">
                        <path d="M8 15A7 7 0 1 1 8 1a7 7 0 0 1 0 14zm0 1A8 8 0 1 0 8 0a8 8 0 0 0 0 16z"/>
                        <path d="M8 4a.5.5 0 0 1 .5.5v3h3a.5.5 0 0 1 0 1h-3v3a.5.5 0 0 1-1 0v-3h-3a.5.5 0 0 1 0-1h3v-3A.5.5 0 0 1 8 4z"/>
                    </svg>
                </button>
                <button class="toggle-btn" data-view="horizontal">
                    <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" viewBox="0 0 16 16">
                        <path d="M2 12.5a.5.5 0 0 1 .5-.5h7a.5.5 0 0 1 0 1h-7a.5.5 0 0 1-.5-.5zm0-3a.5.5 0 0 1 .5-.5h11a.5.5 0 0 1 0 1h-11a.5.5 0 0 1-.5-.5zm0-3a.5.5 0 0 1 .5-.5h7a.5.5 0 0 1 0 1h-7a.5.5 0 0 1-.5-.5zm0-3a.5.5 0 0 1 .5-.5h11a.5.5 0 0 1 0 1h-11a.5.5 0 0 1-.5-.5z"/>
                    </svg>
                </button>
            </div>
        </div>
    </div>

    <div class="timeline-container" id="timeline-container">
        <div class="timeline-stats">
            <div class="stat-card">
                <div class="stat-icon birth">
                    <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" fill="currentColor" viewBox="0 0 16 16">
                        <path d="M8 4.754a3.246 3.246 0 1 0 0 6.492 3.246 3.246 0 0 0 0-6.492zM5.754 8a2.246 2.246 0 1 1 4.492 0 2.246 2.246 0 0 1-4.492 0z"/>
                        <path d="M9.796 1.343c-.527-1.79-3.065-1.79-3.592 0l-.094.319a.873.873 0 0 1-1.255.52l-.292-.16c-1.64-.892-3.433.902-2.54 2.541l.159.292a.873.873 0 0 1-.52 1.255l-.319.094c-1.79.527-1.79 3.065 0 3.592l.319.094a.873.873 0 0 1 .52 1.255l-.16.292c-.892 1.64.901 3.434 2.541 2.54l.292-.159a.873.873 0 0 1 1.255.52l.094.319c.527 1.79 3.065 1.79 3.592 0l.094-.319a.873.873 0 0 1 1.255-.52l.292.16c1.64.893 3.434-.902 2.54-2.541l-.159-.292a.873.873 0 0 1 .52-1.255l.319-.094c1.79-.527 1.79-3.065 0-3.592l-.319-.094a.873.873 0 0 1-.52-1.255l.16-.292c.893-1.64-.902-3.433-2.541-2.54l-.292.159a.873.873 0 0 1-1.255-.52l-.094-.319zm-2.633.283c.246-.835 1.428-.835 1.674 0l.094.319a1.873 1.873 0 0 0 2.693 1.115l.291-.16c.764-.415 1.6.42 1.184 1.185l-.159.292a1.873 1.873 0 0 0 1.116 2.692l.318.094c.835.246.835 1.428 0 1.674l-.319.094a1.873 1.873 0 0 0-1.115 2.693l.16.291c.415.764-.42 1.6-1.185 1.184l-.291-.159a1.873 1.873 0 0 0-2.693 1.116l-.094.318c-.246.835-1.428.835-1.674 0l-.094-.319a1.873 1.873 0 0 0-2.692-1.115l-.292.16c-.764.415-1.6-.42-1.184-1.185l.159-.291A1.873 1.873 0 0 0 1.945 8.93l-.319-.094c-.835-.246-.835-1.428 0-1.674l.319-.094A1.873 1.873 0 0 0 3.06 4.377l-.16-.292c-.415-.764.42-1.6 1.185-1.184l.292.159a1.873 1.873 0 0 0 2.692-1.115l.094-.319z"/>
                    </svg>
                </div>
                <div class="stat-content">
                    <span class="stat-value" id="birth-count">0</span>
                    <span class="stat-label">出生事件</span>
                </div>
            </div>
            <div class="stat-card">
                <div class="stat-icon death">
                    <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" fill="currentColor" viewBox="0 0 16 16">
                        <path d="M8 4.754a3.246 3.246 0 1 0 0 6.492 3.246 3.246 0 0 0 0-6.492zM5.754 8a2.246 2.246 0 1 1 4.492 0 2.246 2.246 0 0 1-4.492 0z"/>
                    </svg>
                </div>
                <div class="stat-content">
                    <span class="stat-value" id="death-count">0</span>
                    <span class="stat-label">逝世事件</span>
                </div>
            </div>
            <div class="stat-card">
                <div class="stat-icon total">
                    <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" fill="currentColor" viewBox="0 0 16 16">
                        <path d="M9.669.864 8 0 6.331.864l-1.858.282-.842 1.68-1.337 1.32L2.6 6l-.306 1.854 1.337 1.32.842 1.68 1.858.282L8 12l1.669-.864 1.858-.282.842-1.68 1.337-1.32L13.4 6l.306-1.854-1.337-1.32-.842-1.68L9.669.864zm1.196 1.142a.68.68 0 0 1 .61.38l.79 1.58a.68.68 0 0 1-.063.727l-1.096 1.313a.68.68 0 0 1-.612.231l-1.748-.265a.68.68 0 0 1-.507-.394l-.736-1.552a.68.68 0 0 1 .072-.706l1.1-1.284a.68.68 0 0 1 .6-.22l1.59.27z"/>
                    </svg>
                </div>
                <div class="stat-content">
                    <span class="stat-value" id="total-events">0</span>
                    <span class="stat-label">总事件数</span>
                </div>
            </div>
        </div>

        <div class="timeline-content" id="timeline-content">
            <div class="timeline-line"></div>
            <div class="timeline-items" id="timeline-items"></div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        window.familyTreeId = '@familyTree?.Id';
        window.membersData = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(members ?? new List<FamilyTreeNew.Models.DTOs.FamilyMemberDto>()));
    </script>
    <script src="~/js/charts/chart-utils.js" asp-append-version="true"></script>
    <script src="~/js/charts/timeline.js" asp-append-version="true"></script>
}
