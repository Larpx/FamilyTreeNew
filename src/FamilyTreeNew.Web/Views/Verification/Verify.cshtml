@model FamilyTreeNew.Web.Controllers.VerificationViewModel
@{
    ViewData["Title"] = "身份验证 - " + Model.FamilyTreeName;
}

<section class="verification-section">
    <div class="verification-bg"></div>
    <div class="container">
        <div class="row justify-content-center">
            <div class="col-lg-6 col-md-8">
                <div class="verification-card">
                    <div class="verification-header">
                        <div class="verification-icon">
                            <svg xmlns="http://www.w3.org/2000/svg" width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                                <rect x="3" y="11" width="18" height="11" rx="2" ry="2"></rect>
                                <path d="M7 11V7a5 5 0 0 1 10 0v4"></path>
                            </svg>
                        </div>
                        <h2 class="verification-title">身份验证</h2>
                        <p class="verification-subtitle">访问家谱需要验证身份</p>
                    </div>

                    <div class="family-info">
                        <div class="family-badge">
                            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                <path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"></path>
                                <circle cx="9" cy="7" r="4"></circle>
                                <path d="M23 21v-2a4 4 0 0 0-3-3.87"></path>
                                <path d="M16 3.13a4 4 0 0 1 0 7.75"></path>
                            </svg>
                            <span>@Model.FamilyTreeName</span>
                        </div>
                        @if (!string.IsNullOrEmpty(Model.FamilyTreeDescription))
                        {
                            <p class="family-desc">@Model.FamilyTreeDescription</p>
                        }
                    </div>

                    <div class="progress-section">
                        <div class="progress-header">
                            <span class="progress-label">验证进度</span>
                            <span class="progress-count">第 @Model.CurrentQuestionOrder 题 / 共 @Model.TotalQuestions 题</span>
                        </div>
                        <div class="progress-bar-container">
                            <div class="progress-bar" style="width: @Model.Progress%"></div>
                        </div>
                    </div>

                    @if (TempData["ErrorMessage"] != null)
                    {
                        <div class="alert alert-error">
                            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                <circle cx="12" cy="12" r="10"></circle>
                                <line x1="15" y1="9" x2="9" y2="15"></line>
                                <line x1="9" y1="9" x2="15" y2="15"></line>
                            </svg>
                            <span>@TempData["ErrorMessage"]</span>
                        </div>
                    }

                    @if (TempData["SuccessMessage"] != null)
                    {
                        <div class="alert alert-success">
                            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                <path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"></path>
                                <polyline points="22 4 12 14.01 9 11.01"></polyline>
                            </svg>
                            <span>@TempData["SuccessMessage"]</span>
                        </div>
                    }

                    <div class="question-section">
                        <div class="question-badge">
                            <span>问题 @Model.CurrentQuestionOrder</span>
                        </div>
                        <h3 class="question-text">@Model.CurrentQuestion.Question</h3>
                    </div>

                    <form asp-action="Verify" method="post" class="verification-form">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="FamilyTreeId" value="@Model.FamilyTreeId" />
                        <input type="hidden" name="QuestionId" value="@Model.CurrentQuestion.Id" />
                        <input type="hidden" name="CurrentQuestionOrder" value="@Model.CurrentQuestionOrder" />

                        <div class="form-group">
                            <label for="Answer" class="form-label">您的答案</label>
                            <input type="text"
                                   id="Answer"
                                   name="Answer"
                                   class="form-input"
                                   placeholder="请输入您的答案..."
                                   autocomplete="off"
                                   required />
                        </div>

                        <div class="form-actions">
                            <button type="submit" class="btn-submit">
                                <span>提交答案</span>
                                <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                    <line x1="5" y1="12" x2="19" y2="12"></line>
                                    <polyline points="12 5 19 12 12 19"></polyline>
                                </svg>
                            </button>
                        </div>
                    </form>

                    <div class="verification-footer">
                        <a asp-controller="Home" asp-action="Index" class="back-link">
                            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                <line x1="19" y1="12" x2="5" y2="12"></line>
                                <polyline points="12 19 5 12 12 5"></polyline>
                            </svg>
                            返回首页
                        </a>
                    </div>
                </div>

                <div class="verification-tips">
                    <div class="tip-item">
                        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                            <circle cx="12" cy="12" r="10"></circle>
                            <line x1="12" y1="16" x2="12" y2="12"></line>
                            <line x1="12" y1="8" x2="12.01" y2="8"></line>
                        </svg>
                        <span>请根据问题提示，输入正确答案以验证身份</span>
                    </div>
                    <div class="tip-item">
                        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                            <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"></path>
                        </svg>
                        <span>验证成功后，24小时内无需再次验证</span>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

<style>
    .verification-section {
        position: relative;
        min-height: calc(100vh - 180px);
        display: flex;
        align-items: center;
        padding: 3rem 0;
        background-color: var(--bg-light);
    }

    .verification-bg {
        position: absolute;
        top: 0;
        left: 0;
        right: 0;
        bottom: 0;
        background: rgba(37, 99, 235, 0.03);
        z-index: 0;
    }

    .verification-card {
        position: relative;
        background: var(--bg-white);
        border-radius: var(--radius-md);
        box-shadow: var(--shadow-lg);
        padding: 2.5rem;
        border: 1px solid var(--border-color);
    }

    .verification-header {
        text-align: center;
        margin-bottom: 2rem;
    }

    .verification-icon {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        width: 80px;
        height: 80px;
        background: var(--color-primary);
        border-radius: 50%;
        color: var(--text-inverse);
        margin-bottom: 1.5rem;
    }

    .verification-title {
        font-family: var(--font-serif);
        font-size: var(--text-xl);
        font-weight: 600;
        color: var(--color-primary);
        margin-bottom: var(--space-2);
    }

    .verification-subtitle {
        color: var(--text-secondary);
        font-size: var(--text-base);
        margin: 0;
    }

    .family-info {
        background: var(--bg-light);
        border-radius: var(--radius-md);
        padding: 1.25rem;
        margin-bottom: 1.5rem;
        border: 1px solid var(--border-color);
    }

    .family-badge {
        display: inline-flex;
        align-items: center;
        gap: var(--space-2);
        background: var(--color-primary);
        color: var(--text-inverse);
        padding: 0.4rem 1rem;
        border-radius: var(--radius-md);
        font-weight: 500;
        font-size: var(--text-sm);
        margin-bottom: 0.75rem;
    }

    .family-desc {
        color: var(--text-secondary);
        font-size: var(--text-sm);
        margin: 0;
        line-height: 1.6;
    }

    .progress-section {
        margin-bottom: 1.5rem;
    }

    .progress-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: var(--space-2);
    }

    .progress-label {
        font-weight: 500;
        color: var(--text-primary);
        font-size: var(--text-sm);
    }

    .progress-count {
        color: var(--text-secondary);
        font-size: var(--text-xs);
    }

    .progress-bar-container {
        height: var(--space-2);
        background: var(--bg-light);
        border-radius: var(--space-1);
        overflow: hidden;
    }

    .progress-bar {
        height: 100%;
        background: var(--color-primary);
        border-radius: var(--space-1);
        transition: width 0.5s ease;
    }

    .alert {
        display: flex;
        align-items: center;
        gap: 0.75rem;
        padding: var(--space-4) 1.25rem;
        border-radius: var(--radius-md);
        margin-bottom: 1.5rem;
        font-size: var(--text-sm);
    }

    .alert-error {
        background-color: var(--color-error-light);
        border: 1px solid var(--color-error);
        color: var(--color-error-dark);
    }

    .alert-success {
        background-color: var(--color-success-light);
        border: 1px solid var(--color-success);
        color: var(--color-success-dark);
    }

    .question-section {
        background: rgba(37, 99, 235, 0.05);
        border-radius: var(--radius-md);
        padding: 1.5rem;
        margin-bottom: 1.5rem;
        border: 1px solid var(--border-color);
    }

    .question-badge {
        display: inline-block;
        background: var(--color-primary);
        color: var(--text-inverse);
        padding: 0.25rem 0.75rem;
        border-radius: var(--space-1);
        font-size: var(--text-xs);
        font-weight: 500;
        margin-bottom: var(--space-4);
    }

    .question-text {
        font-family: var(--font-serif);
        font-size: var(--text-lg);
        font-weight: 600;
        color: var(--text-primary);
        margin: 0;
        line-height: 1.6;
    }

    .verification-form {
        margin-bottom: 1.5rem;
    }

    .form-group {
        margin-bottom: 1.5rem;
    }

    .form-label {
        display: block;
        font-weight: 500;
        color: var(--text-primary);
        margin-bottom: var(--space-2);
        font-size: var(--text-sm);
    }

    .form-input {
        width: 100%;
        padding: 0.875rem var(--space-4);
        font-size: var(--text-base);
        border: 2px solid var(--border-color);
        border-radius: var(--radius-md);
        background: var(--bg-white);
        color: var(--text-primary);
        transition: var(--transition-base);
    }

    .form-input:focus {
        outline: none;
        border-color: var(--color-primary);
        box-shadow: 0 0 0 3px rgba(37, 99, 235, 0.1);
    }

    .form-input::placeholder {
        color: var(--text-tertiary);
    }

    .form-actions {
        display: flex;
        gap: var(--space-4);
    }

    .btn-submit {
        flex: 1;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        gap: var(--space-2);
        padding: var(--space-4) 2rem;
        background: var(--color-primary);
        color: var(--text-inverse);
        border: none;
        border-radius: var(--radius-md);
        font-size: var(--text-base);
        font-weight: 500;
        cursor: pointer;
        transition: var(--transition-base);
    }

    .btn-submit:hover {
        background: var(--color-primary-dark);
        transform: translateY(-2px);
        box-shadow: var(--shadow-md);
    }

    .btn-submit:active {
        transform: translateY(0);
    }

    .verification-footer {
        text-align: center;
        padding-top: var(--space-4);
        border-top: 1px solid var(--border-color);
    }

    .back-link {
        display: inline-flex;
        align-items: center;
        gap: var(--space-2);
        color: var(--text-secondary);
        text-decoration: none;
        font-size: var(--text-sm);
        transition: var(--transition-base);
    }

    .back-link:hover {
        color: var(--color-primary);
    }

    .verification-tips {
        margin-top: 1.5rem;
        padding: var(--space-4);
        background: rgba(255, 255, 255, 0.8);
        border-radius: var(--radius-md);
        border: 1px solid var(--border-color);
    }

    .tip-item {
        display: flex;
        align-items: center;
        gap: var(--space-2);
        color: var(--text-secondary);
        font-size: var(--text-xs);
        margin-bottom: var(--space-2);
    }

    .tip-item:last-child {
        margin-bottom: 0;
    }

    .tip-item svg {
        flex-shrink: 0;
        color: var(--color-primary);
    }

    @@media (max-width: 768px) {
        .verification-section {
            padding: 2rem 0;
            min-height: auto;
        }

        .verification-card {
            padding: 1.5rem;
        }

        .verification-icon {
            width: 60px;
            height: 60px;
        }

        .verification-icon svg {
            width: 32px;
            height: 32px;
        }

        .verification-title {
            font-size: var(--text-lg);
        }

        .question-text {
            font-size: var(--text-base);
        }

        .form-actions {
            flex-direction: column;
        }

        .btn-submit {
            width: 100%;
        }
    }

    @@media (max-width: 576px) {
        .verification-card {
            padding: 1.25rem;
        }

        .verification-title {
            font-size: var(--text-lg);
        }

        .verification-subtitle {
            font-size: var(--text-sm);
        }

        .family-info {
            padding: var(--space-4);
        }

        .question-section {
            padding: var(--space-4);
        }

        .question-text {
            font-size: var(--text-base);
        }

        .progress-header {
            flex-direction: column;
            align-items: flex-start;
            gap: 0.25rem;
        }
    }
</style>

@section Scripts {
    <script>
        document.addEventListener('DOMContentLoaded', function() {
            const form = document.querySelector('.verification-form');
            const submitBtn = document.querySelector('.btn-submit');
            const input = document.querySelector('.form-input');

            input.focus();

            form.addEventListener('submit', function() {
                submitBtn.innerHTML = '<span>验证中...</span>';
                submitBtn.disabled = true;
            });

            const alerts = document.querySelectorAll('.alert');
            alerts.forEach(function(alert) {
                setTimeout(function() {
                    alert.style.opacity = '0';
                    alert.style.transform = 'translateY(-10px)';
                    setTimeout(function() {
                        alert.remove();
                    }, 300);
                }, 5000);
            });
        });
    </script>
}
