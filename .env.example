# ============================================
# FamilyTreeNew 环境变量配置
# 复制此文件为 .env 并修改所有 CHANGE_ME_ 开头的值
# 警告：.env 文件包含敏感信息，切勿提交到版本控制
# ============================================

# MySQL 配置
MYSQL_ROOT_PASSWORD=CHANGE_ME_strong_root_password
MYSQL_USER=familytree
MYSQL_PASSWORD=CHANGE_ME_strong_db_password
MYSQL_PORT=3306

# API 配置
API_PORT=5000
# 必须至少32个字符，建议使用: openssl rand -base64 48
JWT_SECRET_KEY=CHANGE_ME_generate_a_secure_random_key_at_least_32_characters

# Web 配置
WEB_PORT=5002

# 数据库连接字符串（非Docker部署时使用）
# DB_CONNECTION_STRING=Server=127.0.0.1;Port=3306;Database=familytreedb;User=familytree;Password=your_password;CharSet=utf8mb4;
